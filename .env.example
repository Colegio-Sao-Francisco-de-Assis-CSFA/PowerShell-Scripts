# Configurações públicas de exemplo para os scripts deste repositório
# Copie este arquivo para ".env" e ajuste os valores conforme o seu ambiente.

# Caminho base para logs e arquivos temporários gerados pelos scripts.
# Ajuste conforme o perfil do Windows da máquina que executará os scripts.
LOGS_DIR=C:\Users\SEU_USUARIO\Downloads

# Executável do GAM.
# Se o GAM estiver no PATH, normalmente "gam" já funciona.
GAM_EXE=gam

# OU de destino para contas suspensas no Active Directory.
AD_OU_CONTAS_SUSPENSAS=OU=Contas Suspensas,DC=empresa,DC=local

# Org Unit de destino para contas suspensas no Google Workspace.
GOOGLE_ORG_CONTAS_SUSPENSAS=/Contas Suspensas

# Lista de domínios válidos da organização separados por vírgula.
# Preencha com os domínios reais no arquivo ".env" local.
DOMINIOS_GAM_VALIDOS=empresa.com.br,aluno.empresa.com.br
